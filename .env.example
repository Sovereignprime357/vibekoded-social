# vibekoded-social — environment variables
#
# Copy this file to `.env` for LOCAL testing only (`.env` is gitignored —
# never commit real values). In production, these are set as GitHub repo
# Secrets and injected by the workflow YAML files in .github/workflows/,
# NOT read from a committed .env file.

# --- Bluesky credentials -----------------------------------------------
# Create the account first, then Settings -> App Passwords -> create one
# scoped for this bot. NEVER use the account's real login password here.
BSKY_HANDLE=your-handle.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Generation model ----------------------------------------------------
# GEN_MODEL picks which API generate.py calls: "gemini" (default) or "groq".
GEN_MODEL=gemini

# Only the key matching GEN_MODEL needs to be set. If GEN_MODEL=gemini and
# GEMINI_API_KEY is unset (or DRY_RUN=1), generate.py falls back to a
# deterministic stub with NO network call — safe for testing.
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: override the default Groq model (only used when GEN_MODEL=groq).
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Slack (surface + ACT layer, SPEC-v2 T1.5) ---------------------------
# The ACT layer needs a Slack APP with a BOT TOKEN (not the legacy webhook):
# surface.py posts via chat.postMessage so it can capture each message's ts,
# and act_tick.py polls reactions.get on those messages for the operator's 👍.
# Bot token scopes needed: chat:write, reactions:read, channels:history (or
# groups:history for a private channel). Invite the bot to the channel.
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXX
# Optional but recommended (I-HUMAN-GATE): only THIS Slack user's thumbsup
# counts as approval. If unset, any thumbsup in the channel counts.
SLACK_OPERATOR_USER_ID=U0XXXXXXX
# Legacy incoming webhook — still works for surfacing, but items posted this
# way carry no ts and so can NOT be acted on. Prefer the bot token above.
# SLACK_WEBHOOK_URL=

# --- ACT layer per-class daily caps (I-SELECTIVE) ------------------------
# Discerning, low-volume — never farming. Override without a code change.
# ACT_CAP_LIKE=20
# ACT_CAP_REPOST=10
# ACT_CAP_FOLLOW=10
# ACT_CAP_REPLY=5

# --- ACT layer burst protection ------------------------------------------
# Min seconds between executed public actions in a tick, and a hard ceiling on
# executed actions per tick (belt against any mass-fire). Defaults 60 / 3.
# ACT_PACING_SECONDS=60
# ACT_MAX_PER_TICK=3

# --- Conversation-continuation (converse.py) -----------------------------
# When a stranger replies to us, the bot triages (Haiku), drafts a reply-back
# in voice, guards it, and surfaces it to Slack for your 👍 (posted by the ACT
# tick). Human-gated by default — auto-replying to strangers is the riskiest
# action, earned into, never launched with.
#
# AUTO_REPLY_BACK — the earn-it ladder: which reply-back CLASSES may post
# WITHOUT a 👍 (autonomous). Default OFF (everything gated). Values:
#   off | none            -> gated (default)
#   all                   -> every converse class auto-posts
#   appreciation,question -> only these classes auto-post
# Autonomy NEVER extends to scout like/repost/follow, and is still bounded by
# the guard + daily caps + pacing + per-tick cap.
# AUTO_REPLY_BACK=off
# CONVERSE_MAX_THREAD_DEPTH=3     # anti-spiral: max reply-backs proposed per thread
# CONVERSE_TRIAGE_MODEL=anthropic # model for the worth-responding triage

# --- Testing / dry-run ---------------------------------------------------
# Set DRY_RUN=1 to run the full pipeline (queue -> generate -> guard) WITHOUT
# making any real network calls to Bluesky or the gen model, and WITHOUT
# needing any credentials above. post_tick.py / banter.py print exactly
# what they WOULD post/reply instead of posting it.
DRY_RUN=0

# --- Privacy-guard extra terms (client/project-confidential) --------------
# CRITICAL: this repo is PUBLIC. Client names, project codenames, and any
# confidential term must NEVER be committed. guard.py merges extra terms, on
# top of the hardcoded floor (personal names + family), from NON-committed
# sources only:
#   - GUARD_EXTRA_TERMS   — comma- OR newline-separated. In CI this is a
#                           GitHub *secret*. This is the primary channel.
#   - guard-extra-terms.txt — a gitignored file beside the code (one term per
#                           line, '#' comments ok) for local runs. Override the
#                           path with GUARD_EXTRA_TERMS_FILE.
# The hardcoded floor can never be weakened via env, file, or config.
# GUARD_EXTRA_TERMS=asphalt-solutions,client-codename
# GUARD_EXTRA_TERMS_FILE=./guard-extra-terms.txt
#
# (Legacy: EXTRA_TERMS_CSV / config.EXTRA_TERMS still work but should stay
# empty in this public repo — real terms go in the two channels above.)
# EXTRA_TERMS_CSV=

# --- Optional: alternate file locations -----------------------------------
# Override where queue.py reads/writes the handoff file. Defaults to
# ./content-queue.jsonl next to this file.
# QUEUE_PATH=./content-queue.jsonl
