# vibekoded-social — environment variables
#
# Copy this file to `.env` for LOCAL testing only (`.env` is gitignored —
# never commit real values). In production, these are set as GitHub repo
# Secrets and injected by the workflow YAML files in .github/workflows/,
# NOT read from a committed .env file.

# --- Bluesky credentials -----------------------------------------------
# Create the account first, then Settings -> App Passwords -> create one
# scoped for this bot. NEVER use the account's real login password here.
BSKY_HANDLE=your-handle.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Generation model ----------------------------------------------------
# GEN_MODEL picks which API generate.py calls: "gemini" (default) or "groq".
GEN_MODEL=gemini

# Only the key matching GEN_MODEL needs to be set. If GEN_MODEL=gemini and
# GEMINI_API_KEY is unset (or DRY_RUN=1), generate.py falls back to a
# deterministic stub with NO network call — safe for testing.
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: override the default Groq model (only used when GEN_MODEL=groq).
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Testing / dry-run ---------------------------------------------------
# Set DRY_RUN=1 to run the full pipeline (queue -> generate -> guard) WITHOUT
# making any real network calls to Bluesky or the gen model, and WITHOUT
# needing any credentials above. post_tick.py / banter.py print exactly
# what they WOULD post/reply instead of posting it.
DRY_RUN=0

# --- Privacy-guard extra terms (client/project-confidential) --------------
# CRITICAL: this repo is PUBLIC. Client names, project codenames, and any
# confidential term must NEVER be committed. guard.py merges extra terms, on
# top of the hardcoded floor (personal names + family), from NON-committed
# sources only:
#   - GUARD_EXTRA_TERMS   — comma- OR newline-separated. In CI this is a
#                           GitHub *secret*. This is the primary channel.
#   - guard-extra-terms.txt — a gitignored file beside the code (one term per
#                           line, '#' comments ok) for local runs. Override the
#                           path with GUARD_EXTRA_TERMS_FILE.
# The hardcoded floor can never be weakened via env, file, or config.
# GUARD_EXTRA_TERMS=asphalt-solutions,client-codename
# GUARD_EXTRA_TERMS_FILE=./guard-extra-terms.txt
#
# (Legacy: EXTRA_TERMS_CSV / config.EXTRA_TERMS still work but should stay
# empty in this public repo — real terms go in the two channels above.)
# EXTRA_TERMS_CSV=

# --- Optional: alternate file locations -----------------------------------
# Override where queue.py reads/writes the handoff file. Defaults to
# ./content-queue.jsonl next to this file.
# QUEUE_PATH=./content-queue.jsonl
